<pre class="overflow-visible! px-0!" data-start="743" data-end="1376"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#e45ab3" fill="currentColor"></use></svg>CSS</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼ6">/* HERO */</span><br><span>.</span><span class="ͼd">hero</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">64</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">100</span><span class="ͼ8">vh</span><span>;</span><br><span>  position: </span><span class="ͼb">relative</span><span>;</span><br><span>  overflow: </span><span class="ͼb">hidden</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* SLIDER */</span><br><span>.</span><span class="ͼd">slider</span><span> {</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  inset: </span><span class="ͼb">0</span><span>;</span><br><span>  z-index: </span><span class="ͼb">1</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">slide</span><span> {</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  width: </span><span class="ͼb">100</span><span class="ͼ8">%</span><span>;</span><br><span>  height: </span><span class="ͼb">100</span><span class="ͼ8">%</span><span>;</span><br><span>  object-fit: </span><span class="ͼb">cover</span><span>;</span><br><span>  opacity: </span><span class="ͼb">0</span><span>;</span><br><span>  transform: </span><span class="ͼ8">scale</span><span>(</span><span class="ͼb">1.1</span><span>); </span><span class="ͼ6">/* zoom effect */</span><br><span>  transition: </span><span class="ͼb">opacity</span><span> </span><span class="ͼb">1</span><span class="ͼ8">s</span><span> </span><span class="ͼb">ease</span><span>, </span><span class="ͼb">transform</span><span> </span><span class="ͼb">6</span><span class="ͼ8">s</span><span> </span><span class="ͼb">ease</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">slide</span><span>.</span><span class="ͼd">active</span><span> {</span><br><span>  opacity: </span><span class="ͼb">1</span><span>;</span><br><span>  transform: </span><span class="ͼ8">scale</span><span>(</span><span class="ͼb">1</span><span>); </span><span class="ͼ6">/* smooth zoom */</span><br><span>}</span><br><br><span class="ͼ6">/* DARK PREMIUM OVERLAY */</span><br><span>.</span><span class="ͼd">overlay</span><span> {</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  inset: </span><span class="ͼb">0</span><span>;</span><br><span>  background: </span><span class="ͼ8">linear-gradient</span><span>(</span><br><span>    </span><span class="ͼ8">rgba</span><span>(</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0.6</span><span>),</span><br><span>    </span><span class="ͼ8">rgba</span><span>(</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0.6</span><span>)</span><br><span>  );</span><br><span>  z-index: </span><span class="ͼb">2</span><span>;</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="1378" data-end="1381">
