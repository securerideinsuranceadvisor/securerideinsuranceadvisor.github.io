&lt;/html&gt; index html          and script js    / Slider
let slides = document.querySelectorAll('.slide');     and  style css  
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

body {
  background: #f4f6fb;
  color: #222;
}

/* HEADER */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  height: 64px;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 14px;
  box-shadow: 0 2px 10px rgba(0,0,0,.1);
  z-index: 100;
}

.logo-box {
  display: flex;
  align-items: center;
  gap: 8px;
}

.logo-box img {
  height: 34px;
}

.whatsapp-btn {
  background: #25D366;
  color: #fff;
  padding: 8px 14px;
  border-radius: 20px;
  text-decoration: none;
  font-size: 14px;
}

/* HERO */
.hero {
  margin-top: 64px;
  min-height: calc(100vh - 64px);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* SLIDER */
.slider {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.slide {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 1s ease;
}

.slide.active {
  opacity: 1;
}

/* FORM */
.quote-box {
  position: relative;
  z-index: 2;
  background: #fff;
  padding: 24px;
  border-radius: 16px;
  width: 90%;
  max-width: 380px;
  text-align: center;
  box-shadow: 0 15px 35px rgba(0,0,0,.3);
}

.quote-box h1 {
  font-size: 22px;
  margin-bottom: 6px;
}

.quote-box p {
  font-size: 14px;
  color: #555;
  margin-bottom: 12px;
}

.quote-box input {
  width: 100%;
  padding: 10px;
  margin-bottom: 10px;
  border-radius: 8px;
  border: 1px solid #ccc;
}

.quote-box button {
  width: 100%;
  padding: 12px;
  background: #0a58ca;
  color: #fff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
}

.quote-box small {
  display: block;
  margin-top: 8px;
  font-size: 11px;
  color: #666;
}

/* TAGS */
.vehicle-tags {
  position: absolute;
  bottom: 20px;
  z-index: 2;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
  padding: 0 10px;
}

.vehicle-tags span {
  background: rgba(255,255,255,.9);
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
}

/* SECTIONS */
.section {
  padding: 50px 16px;
  text-align: center;
}

.section.light {
  background: #eef1f7;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 14px;
  margin-top: 20px;
}

.grid div {
  background: #fff;
  padding: 14px;
  border-radius: 12px;
  box-shadow: 0 6px 15px rgba(0,0,0,.1);
}

/* DISCLAIMER */
.disclaimer {
  background: #f0f2f8;
  padding: 16px;
  font-size: 12px;
  text-align: center;
}

/* FOOTER */
.footer {
  background: #111;
  color: #aaa;
  text-align: center;
  padding: 14px;
  font-size: 12px;
} 
let index = 0;

setInterval(() =&gt; {
  slides[index].classList.remove('active');
  index = (index + 1) % slides.length;
  slides[index].classList.add('active');
}, 4000);

// WhatsApp Form
function sendToWhatsApp(e) {
  e.preventDefault();

  const vehicle = document.getElementById("vehicle").value;
  const mobile = document.getElementById("mobile").value;

  const message =
    <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">Hello, I need vehicle insurance assistance.\n\n</code> +
    <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">Vehicle Number: ${vehicle}\n</code> +
    <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">Mobile: ${mobile}</code>;

  const url = <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">https://wa.me/917633801161?text=${encodeURIComponent(message)}</code>;
