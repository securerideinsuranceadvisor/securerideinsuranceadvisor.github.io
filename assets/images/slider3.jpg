let slides = document.querySelectorAll('.slide');
let index = 0;

setInterval(() =&gt; {
  slides[index].classList.remove('active');
  index = (index + 1) % slides.length;
  slides[index].classList.add('active');
}, 4000);

// WhatsApp Form
function sendToWhatsApp(e) {
  e.preventDefault();

  const vehicle = document.getElementById("vehicle").value;
  const mobile = document.getElementById("mobile").value;

  const message =
    <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">Hello, I need vehicle insurance assistance.\n\n</code> +
    <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">Vehicle Number: ${vehicle}\n</code> +
    <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">Mobile: ${mobile}</code>;

  const url = <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">https://wa.me/917633801161?text=${encodeURIComponent(message)}</code>;
  window.open(url, "_blank");
}         index file    &lt;!DOCTYPE html&gt;
&lt;html lang="en"&gt;
&lt;head&gt;
  &lt;meta charset="UTF-8" /&gt;
  &lt;title&gt;SecureRide Insurance Advisor&lt;/title&gt;
  &lt;meta name="viewport" content="width=device-width, initial-scale=1.0" /&gt;
  &lt;meta name="description" content="Car and Bike insurance assistance for renewal, new policy and claim guidance as per IRDAI guidelines." /&gt;
  &lt;link rel="stylesheet" href="style.css" /&gt;
&lt;/head&gt;

&lt;body&gt;

&lt;!-- HEADER --&gt;
&lt;header class="header"&gt;
  &lt;div class="logo-box"&gt;
    &lt;img src="assets/images/logo.png" alt="SecureRide Logo"&gt;
    &lt;span&gt;SecureRide Insurance Advisor&lt;/span&gt;
  &lt;/div&gt;
  &lt;a href="https://wa.me/917633801161" class="whatsapp-btn" target="_blank"&gt;
    WhatsApp Now
  &lt;/a&gt;
&lt;/header&gt;

&lt;!-- HERO --&gt;
&lt;section class="hero"&gt;

  &lt;!-- SLIDER --&gt;
  &lt;div class="slider"&gt;
    &lt;img src="assets/images/slider2.jpg" class="slide active"&gt;
    &lt;img src="assets/images/slider3.jpg" class="slide"&gt;
  &lt;/div&gt;

  &lt;!-- FORM --&gt;
  &lt;div class="quote-box"&gt;
    &lt;h1&gt;Vehicle Insurance Assistance&lt;/h1&gt;
    &lt;p&gt;Car &amp; Bike • Renewal • New Policy&lt;/p&gt;

    &lt;form onsubmit="sendToWhatsApp(event)"&gt;
      &lt;input type="text" id="vehicle" placeholder="Vehicle Number" required /&gt;
      &lt;input type="tel" id="mobile" placeholder="Mobile Number" required /&gt;
      &lt;button type="submit"&gt;Request Assistance&lt;/button&gt;
    &lt;/form&gt;

    &lt;small&gt;
      We provide insurance assistance only. Policy issuance is subject to insurer terms.
    &lt;/small&gt;
  &lt;/div&gt;

  &lt;!-- VEHICLE TAGS --&gt;
  &lt;div class="vehicle-tags"&gt;
    &lt;span&gt;✔ Two Wheeler&lt;/span&gt;
    &lt;span&gt;✔ Four Wheeler&lt;/span&gt;
    &lt;span&gt;✔ Private Car&lt;/span&gt;
    &lt;span&gt;✔ Bike&lt;/span&gt;
    &lt;span&gt;✔ Commercial Vehicle&lt;/span&gt;
  &lt;/div&gt;

&lt;/section&gt;

&lt;!-- POLICY TYPES --&gt;
&lt;section class="section"&gt;
  &lt;h2&gt;Policy Types Supported&lt;/h2&gt;
  &lt;div class="grid"&gt;
    &lt;div&gt;Comprehensive Policy&lt;/div&gt;
    &lt;div&gt;Third Party Policy&lt;/div&gt;
    &lt;div&gt;Own Damage Cover&lt;/div&gt;
    &lt;div&gt;Add-on Guidance&lt;/div&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;!-- WHY US --&gt;
&lt;section class="section light"&gt;
  &lt;h2&gt;Why Choose Us&lt;/h2&gt;
  &lt;div class="grid"&gt;
    &lt;div&gt;Experienced Insurance Assistance&lt;/div&gt;
    &lt;div&gt;Transparent Process&lt;/div&gt;
    &lt;div&gt;Renewal Support&lt;/div&gt;
    &lt;div&gt;Claim Guidance&lt;/div&gt;
    &lt;div&gt;Privacy Focused&lt;/div&gt;
    &lt;div&gt;WhatsApp Support&lt;/div&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;!-- DISCLAIMER --&gt;
&lt;section class="disclaimer"&gt;
  &lt;p&gt;
    &lt;strong&gt;Disclaimer:&lt;/strong&gt; SecureRide Insurance Advisor provides assistance and information only.
    Insurance policies are issued by respective insurers. Coverage, premium and claims are subject to
    insurer terms and IRDAI regulations. We do not guarantee approval, pricing or claim settlement.
  &lt;/p&gt;
&lt;/section&gt;

&lt;!-- FOOTER --&gt;
&lt;footer class="footer"&gt;
  © 2026 SecureRide Insurance Advisor. All Rights Reserved.
&lt;/footer&gt;

&lt;script src="script.js"&gt;&lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;     csss file    * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

body {
  background: #f4f6fb;
  color: #222;
}

/* HEADER */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  height: 64px;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 14px;
  box-shadow: 0 2px 10px rgba(0,0,0,.1);
  z-index: 100;
}

.logo-box {
  display: flex;
  align-items: center;
  gap: 8px;
}

.logo-box img {
  height: 34px;
}

.whatsapp-btn {
  background: #25D366;
  color: #fff;
  padding: 8px 14px;
  border-radius: 20px;
  text-decoration: none;
  font-size: 14px;
}

/* HERO */
.hero {
  margin-top: 64px;
  min-height: calc(100vh - 64px);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* SLIDER */
.slider {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.slide {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 1s ease;
}

.slide.active {
  opacity: 1;
}

/* FORM */
.quote-box {
  position: relative;
  z-index: 2;
  background: #fff;
  padding: 24px;
  border-radius: 16px;
  width: 90%;
  max-width: 380px;
  text-align: center;
  box-shadow: 0 15px 35px rgba(0,0,0,.3);
}

.quote-box h1 {
  font-size: 22px;
  margin-bottom: 6px;
}

.quote-box p {
  font-size: 14px;
  color: #555;
  margin-bottom: 12px;
}

.quote-box input {
  width: 100%;
  padding: 10px;
  margin-bottom: 10px;
  border-radius: 8px;
  border: 1px solid #ccc;
}

.quote-box button {
  width: 100%;
  padding: 12px;
  background: #0a58ca;
  color: #fff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
}

.quote-box small {
  display: block;
  margin-top: 8px;
  font-size: 11px;
  color: #666;
}

/* TAGS */
.vehicle-tags {
  position: absolute;
  bottom: 20px;
  z-index: 2;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
  padding: 0 10px;
}

.vehicle-tags span {
  background: rgba(255,255,255,.9);
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
}

/* SECTIONS */
.section {
  padding: 50px 16px;
  text-align: center;
}

.section.light {
  background: #eef1f7;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 14px;
  margin-top: 20px;
}

.grid div {
  background: #fff;
  padding: 14px;
  border-radius: 12px;
  box-shadow: 0 6px 15px rgba(0,0,0,.1);
}

/* DISCLAIMER */
.disclaimer {
  background: #f0f2f8;
  padding: 16px;
  font-size: 12px;
  text-align: center;
}

/* FOOTER */
.footer {
  background: #111;
  color: #aaa;
  text-align: center;
  padding: 14px;
  font-size: 12px;
}     provide a proffesional website so that i get number of customers for insurance and iam certified advicor</div></div></div></div><div class="text-token-text-secondary my-2 me-4 flex flex-row justify-end gap-1 text-xs"></div></div><div class="z-0 flex justify-end"><div aria-label="Your message actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none focus-within:transition-none hover:transition-none touch:pointer-events-auto touch:opacity-100 duration-300 group-hover/turn-messages:delay-300 pointer-events-none opacity-0 motion-safe:transition-opacity group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:opacity-100 group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:opacity-100 has-data-[state=open]:pointer-events-auto has-data-[state=open]:opacity-100" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy message" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Edit message" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#6d87e1" fill="currentColor"></use></svg></span></button></div></div></div></div><span class="sr-only"><br></span></section><section class="text-token-text-primary w-full focus:outline-none [--shadow-height:45px] has-data-writing-block:pointer-events-none has-data-writing-block:-mt-(--shadow-height) has-