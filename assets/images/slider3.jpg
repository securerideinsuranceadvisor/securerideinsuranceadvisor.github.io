d(</span><span class="ͼc">'name'</span><span>)</span><span class="ͼ8">.</span><span>value;</span><br><span> </span><span class="ͼ8">const</span><span> </span><span class="ͼe">vehicle</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">document</span><span class="ͼ8">.</span><span>getElementById(</span><span class="ͼc">'vehicle'</span><span>)</span><span class="ͼ8">.</span><span>value;</span><br><span> </span><span class="ͼ8">const</span><span> </span><span class="ͼe">mobile</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">document</span><span class="ͼ8">.</span><span>getElementById(</span><span class="ͼc">'mobile'</span><span>)</span><span class="ͼ8">.</span><span>value;</span><br><br><span> </span><span class="ͼ8">await</span><span> </span><span class="ͼe">db</span><span class="ͼ8">.</span><span>collection(</span><span class="ͼc">'leads'</span><span>)</span><span class="ͼ8">.</span><span>add({</span><br><span>   name, vehicle, mobile,</span><br><span>   created: </span><span class="ͼ8">new</span><span> </span><span class="ͼe">Date</span><span>()</span><br><span> });</span><br><br><span> </span><span class="ͼ8">const</span><span> </span><span class="ͼe">msg</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼc">`Hello, I need insurance</span><span class="ͼi">\n</span><span class="ͼc">Name:</span><span>${</span><span class="ͼe">name</span><span>}</span><span class="ͼi">\n</span><span class="ͼc">Vehicle:</span><span>${</span><span class="ͼe">vehicle</span><span>}</span><span class="ͼi">\n</span><span class="ͼc">Mobile:</span><span>${</span><span class="ͼe">mobile</span><span>}</span><span class="ͼc">`</span><span>;</span><br><span> </span><span class="ͼe">window</span><span class="ͼ8">.</span><span>open(</span><span class="ͼc">`https://wa.me/917633801161?text=</span><span>${</span><span class="ͼe">encodeURIComponent</span><span>(</span><span class="ͼe">msg</span><span>)}</span><span class="ͼc">`</span><span>);</span><br><span>});</span><br><span class="ͼg">&lt;/script&gt;</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
